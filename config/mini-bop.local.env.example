# Mini BOP - Local WSL environment template
# Source manually or copy the values into your shell profile when useful.

export MINI_BOP_PROJECT_ROOT=/mnt/f/SSD_DEV/windows/projects/mini-bop
export MINI_BOP_API_PORT=8010
export MINI_BOP_API_BASE=http://localhost:8010
export MINI_BOP_HDFS_BASE=hdfs://localhost:9000/data/mini_bop
